# -----------------------------------------------------------------------------
# prio (formerly The Last-Minute Life Saver) — Environment Configuration Template
# Copy this file to .env and fill in the values for local development.
# -----------------------------------------------------------------------------

# --- Convex Database Configuration ---
# The URL of your active Convex deployment (can be found in the Convex Dashboard or .env.local)
CONVEX_URL=https://your-convex-deployment-name.convex.cloud

# The deploy key generated for local or production build pipeline verification
CONVEX_DEPLOY_KEY=dev:your-convex-deployment-name|eyJ...

# --- OAuth 2.0 Integrations (Google Cloud Workspace APIs) ---
# Create these credentials under Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Session & Security Tokens ---
# Generate a secure 32-byte hex string (e.g. run: openssl rand -hex 32)
SESSION_SECRET=your-secure-session-signing-key-32-bytes-hex

# Internal service-to-service authentication secret key
INTERNAL_API_SECRET=your-internal-service-to-service-api-secret

# Key ID used for encrypting OAuth tokens before saving to Convex database (mock:// is supported for local dev)
KMS_KEY_ID=mock://local-dev-mock-kms-passphrase-32b

# --- Background Task Queueing & Cache ---
# Upstash Redis database URI or local Redis connection address
REDIS_ADDR=localhost:6379

# --- Google Pub/Sub Webhook Watcher ---
# Google Cloud Pub/Sub topic string for watch notifications
GMAIL_PUBSUB_TOPIC=projects/your-gcp-project-id/topics/gmail-watch-notifications

# The target audience URI for verifying Webhooks callback invocations
WEBHOOK_AUDIENCE=http://localhost:8080/tasks/execute

# Set to true during local development to disable OIDC verification for simulated Pub/Sub endpoints
DISABLE_OIDC_VALIDATION=true
